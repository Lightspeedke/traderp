# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public URL where this app is hosted.
# On Vercel, set this to your production domain, e.g. https://your-app.vercel.app.
# Used for PayHero callback URLs.
APP_URL="https://your-app.vercel.app"

# PayHero MPESA STK Push integration is configured directly in api/_utils.ts.
