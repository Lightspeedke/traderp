# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public URL where this app is hosted.
# On Vercel, set this to your production domain, e.g. https://your-app.vercel.app.
# Used for PayHero callback URLs.
APP_URL="https://your-app.vercel.app"

# PayHero MPESA STK Push integration.
# Store these values securely and do NOT commit actual credentials to source control.
PAYHERO_API_USERNAME="YOUR_PAYHERO_API_USERNAME"
PAYHERO_API_PASSWORD="YOUR_PAYHERO_API_PASSWORD"
PAYHERO_BASIC_AUTH_TOKEN="Basic YOUR_PAYHERO_BASIC_AUTH_TOKEN"
PAYHERO_CHANNEL_ID="1567"
PAYHERO_ACCOUNT_ID=""
# Optional: If using your own Daraja credentials, provide the credential_id.
PAYHERO_CREDENTIAL_ID=""
# Optional override for the PayHero endpoint.
PAYHERO_API_URL="https://backend.payhero.co.ke/api/v2/payments"
